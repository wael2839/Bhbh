{
  "name": "mudad-dashboard",
  "private": true,
  "main": "app.cjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:quick": "concurrently -k \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "node server/index.mjs",
    "start": "node app.cjs",
    "build": "vite build",
    "pack": "node scripts/pack-deploy.mjs",
    "preview": "concurrently -k \"npm run server\" \"vite preview\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
