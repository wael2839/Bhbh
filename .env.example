# انسخ هذا الملف إلى .env واملأ القيم من DevTools → Network في mudad.com.sa
# ⚠️ لا ترفع ملف .env إلى Git

MUDAD_BASE_URL=https://api.mudad.sa
MUDAD_BEARER_TOKEN=
MUDAD_API_KEY=
MUDAD_ORG_ID=
MUDAD_SESSION_ID=
MUDAD_SYSTEM_TYPE=MUDAD_COMPLIANCE_APP

# مسار قائمة الملفات المرفوعة (من DevTools → submitted-files)
MUDAD_FILES_PATH=/compliance/resources/v1/establishment/mlsd-unified-id/submitted-files
MUDAD_FILE_DETAIL_PATH=
MUDAD_UPLOAD_PATH=/compliance/v1/upload-wage-file
MUDAD_UPLOAD_CHECK_PATH=/compliance/resources/v1/wps-bank-integrated-services
MUDAD_MLSD_UNIFIED_ID=
MUDAD_FILE_TYPE=1000
MUDAD_WAGE_FREQUENCY=1001

PORT=3001
